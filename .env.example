# Local development ports. No secrets should be stored here.
# Copy this file to .env and fill in your values.
API_HOST=127.0.0.1
API_PORT=8900
WEB_PORT=3900
NEXT_PUBLIC_API_BASE_URL=http://localhost:8900
CAD_BACKEND=fake
# Chat CAD generation path: sync keeps legacy behavior; async enables real-time Agent Run job streaming.
CHAT_GENERATION_MODE=sync
# Fake backend QA knobs.
FAKE_CAD_STEP_DELAY_MS=0
# FAKE_CAD_FAIL_STAGE=glb_exported
# RUN_VSPAERO_ANALYSIS=false
# OPENVSP_ERROR_POLICY=warn
NO_TOOL_CALL_FALLBACK=true
NO_TOOL_CALL_FALLBACK_MIN_CONFIDENCE=0.6
# OPENVSP_ROOT=/home/z/.local/opt/OpenVSP-3.50.2
# OPENVSP_LIB_DIR=/home/z/.local/opt/openvsp-libs/root/usr/lib/x86_64-linux-gnu
# LD_LIBRARY_PATH=/home/z/.local/opt/openvsp-libs/root/usr/lib/x86_64-linux-gnu
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
